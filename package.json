{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "description": "Himabindhu Eye Testing & Opticals App",
  "author": "Himabindhu",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --port=3000 --host=0.0.0.0",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "node node_modules/electron/cli.js .",
    "electron:package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-sitemap": "^0.8.2"
  },
  "build": {
    "appId": "com.himabindhu.eyetest",
    "productName": "Himabindhu Opticals",
    "directories": {
      "output": "C:/Users/Banu Prakash/himabindhu-build"
    },
    "win": {
      "target": "nsis",
      "icon": "public/realistic_eye_logo.png"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "asar": true
  }
